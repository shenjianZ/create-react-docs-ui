{
    "name": "create-react-docs-ui",
    "version": "0.6.17",
    "private": false,
    "type": "module",
    "bin": {
        "create-react-docs-ui": "./index.js"
    },
    "files": [
        "index.js",
        "template/index.html",
        "template/package.json",
        "template/vite-plugin-mdx-components.ts",
        "template/vite.config.ts",
